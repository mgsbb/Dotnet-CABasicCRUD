@using CABasicCRUD.Application.Common.Interfaces
@inject ICurrentUser CurrentUser



<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js"></script>
</head>

<body id="app-layout" class="sidebar-expanded">

    <!-- backdrop for mobile -->
    <div id="backdrop" onclick="toggleSidebar()" class="fixed inset-0 bg-black/40 hidden md:hidden">
    </div>

    @* sidebar *@
    <aside id="sidebar"
           class="fixed left-0 top-0 h-screen bg-white border-r border-gray-300 p-4 transition-all duration-300">

        <button type="button" onclick="toggleSidebar()" class="text-gray-500 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                 stroke="currentColor" class="size-8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
        </button>

        @* user details *@
        <div class="sidebar-user-details px-4 py-10 flex flex-col gap-4 items-center">
            @* replace with user profile image *@
            <div class="border border-gray-400 rounded-sm p-4 w-32 h-32"></div>
            @* replace with username instead *@
            <p class="font-bold text-gray-700">
                <a href="/users/@CurrentUser.UserId">
                    @CurrentUser.Username
                </a>
            </p>
        </div>

        <div class="px-10 py-10 h-10 flex flex-col gap-8 text-gray-500 text-lg font-medium w-full">
            @* home icon *@
            <a href="/" class="inline-flex gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                     stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
                </svg>
                <span class="sidebar-label">Home</span>
            </a>

            @* posts *@
            <a href="/posts" class="inline-flex gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                     stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
                </svg>
                <span class="sidebar-label">Posts</span>
            </a>

            @* posts *@
            <a href="/users" class="inline-flex gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                     stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                </svg>
                <span class="sidebar-label">Users</span>
            </a>
        </div>
    </aside>

    @* top navbar *@
    <header id="header" class="fixed top-0 h-16 w-full bg-white border-b border-gray-300 z-10 p-4">
        <nav>
            <button type="button" onclick="toggleSidebar()" class="text-gray-500 cursor-pointer md:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                     stroke="currentColor" class="size-8">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
        </nav>
    </header>

    <main id="main" class="bg-gray-100 min-h-screen">
        @RenderBody()
    </main>
</body>

</html>