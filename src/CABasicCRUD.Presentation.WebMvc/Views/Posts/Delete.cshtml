@{
    ViewData["Title"] = "Delete Post";
}


<section class="flex flex-col gap-10">

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="flex flex-col gap-2 items-center mt-20">
            <div asp-validation-summary="ModelOnly"
                 class="bg-red-100 text-red-700 font-semibold px-4 py-2 mb-10 rounded-sm">
            </div>
            <a href="/posts" class="text-gray-600 font-medium">Back to posts</a>
        </div>
    }
    else
    {
        <h1 class="text-3xl font-medium text-gray-700 text-center">Delete Post</h1>

        <div class="flex flex-col gap-8 items-center ">
            <p class="text-center">
                Are you sure you want to delete
                <strong>@Model.Title</strong>?
            </p>

            <form method="post" class="flex flex-col sm:flex-row gap-4 sm:gap-20 sm:justify-between items-center">
                <button type="submit" class="bg-red-100 text-red-700 px-4 py-2 rounded-sm font-semibold cursor-pointer">
                    Yes, delete
                </button>
                <a href="/posts/@Model.Id">
                    <button type="button"
                            class="text-gray-700 bg-gray-100 px-4 py-2 rounded-sm font-semibold cursor-pointer">
                        Cancel
                    </button>
                </a>
            </form>
        </div>
    }
</section>