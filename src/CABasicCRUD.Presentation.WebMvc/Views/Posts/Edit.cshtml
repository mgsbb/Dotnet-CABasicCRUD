@model CABasicCRUD.Presentation.WebMvc.Models.Posts.PostEditViewModel
@{
    ViewData["Title"] = "Edit Post";
}


<section class="flex flex-col gap-6">

    <h1 class="text-3xl font-medium text-gray-700 text-center">Edit Post</h1>

    @* to display: "Cannot edit post of another user" *@
    @* to display: "At least one field must be provided." *@
    @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
    {
        <div class="flex flex-col gap-2 items-center">
            <div asp-validation-summary="ModelOnly"
                 class="bg-red-100 text-red-700 font-semibold px-4 py-2 mb-10 rounded-sm">
            </div>

            @* <div asp-validation-summary="All" class="bg-red-100 text-red-700 font-semibold px-4 py-2 mb-10 rounded-sm">
        </div> *@
            @* <a href="/posts" class="text-gray-600 font-medium">Back to posts</a> *@
        </div>
    }

    <form asp-controller="Posts" asp-action="Edit" method="post" class="flex flex-col gap-10 w-5/6 lg:w-3/4 mx-auto">
        <div class="flex flex-col gap-1">
            <label for="Title" class="font-medium text-gray-500">Title</label>
            <input asp-for="Title" class="border border-gray-300 rounded-sm p-2" />
            <span asp-validation-for="Title" class="text-sm font-semibold text-red-600"></span>
        </div>

        <div class="flex flex-col gap-1">
            <label for="Content" class="font-medium text-gray-500">Content</label>
            <textarea asp-for="Content" class="border border-gray-300 rounded-sm p-2" rows="15"></textarea>
            <span asp-validation-for="Content" class="text-sm font-semibold text-red-600"></span>
        </div>

        <button type="submit" class="bg-gray-900 text-white py-3 rounded-sm cursor-pointer font-semibold text-sm">
            Edit
        </button>
    </form>

</section>